# ---- Application ----
# Secret used to sign session cookies and reset tokens. Generate a long random value.
SECRET_KEY=change-me-to-a-long-random-string

# ---- Database ----
# Full SQLAlchemy URL. In docker-compose this points at the "db" service.
DATABASE_URL=postgresql+psycopg2://sumo:sumo@db:5432/sumo

# ---- Email (password reset) ----
# If EMAIL_BACKEND=console, reset codes are printed to the app logs (handy for local dev).
# Set EMAIL_BACKEND=smtp and fill the SMTP_* values to send real e-mails.
EMAIL_BACKEND=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@sumo.local
SMTP_USE_TLS=true

# ---- Misc ----
# Items per page on the competitions list.
PAGE_SIZE=10
